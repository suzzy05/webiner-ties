# Optional, used only to set correct canonical URLs in metadata.
# Example: https://tiesverse.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google Maps Embed API key (required for map embeds on event detail pages).
# Get yours at: https://console.cloud.google.com/apis/credentials
# Enable: "Maps Embed API" for your project.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Database URL. Local SQLite file for dev; Turso cloud URL for production.
# Default is file:./.data/tiesverse.db if unset.
DATABASE_URL="file:./.data/tiesverse.db"

# Auth token required when DATABASE_URL points to a Turso cloud database.
# Generate with: turso db tokens create <db-name>
# Leave empty for local file-based SQLite.
DATABASE_AUTH_TOKEN=""

# Simple admin password for /admin (set to something non-trivial, min 12 chars).
ADMIN_PASSWORD="change-me"

# Optional: extra secret used to sign admin session cookies.
# Falls back to ADMIN_PASSWORD if not set.
# ADMIN_SECRET="a-long-random-string"

# SendGrid API key for registration confirmation emails.
# Get yours at: https://sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=""

# Verified sender email address in your SendGrid account.
SENDGRID_FROM_EMAIL="no-reply@tiesverse.com"
